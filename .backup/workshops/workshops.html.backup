<app-layout>
    <div class="workshops-container animate-fade-in">
        @if (showWorkshopEnrollment() && selectedWorkshop()) {
        <div class="research-form-container animate-fade-in">
            <button class="btn-back" (click)="closeWorkshopEnrollment()" style="margin-bottom: 1.5rem;">
                <i class="fas fa-arrow-left"></i> Back to Workshops
            </button>

            <div class="workshop-preview-card">
                <h2 class="workshop-title">{{ selectedWorkshop().title }}</h2>
                <p class="workshop-desc">{{ selectedWorkshop().description }}</p>
                <div class="workshop-meta">
                    <span><i class="fas fa-user-tie"></i> {{ selectedWorkshop().instructor }}</span>
                    <span><i class="fas fa-calendar-day"></i> {{ selectedWorkshop().date }}</span>
                    <span><i class="fas fa-clock"></i> {{ selectedWorkshop().duration }}</span>
                    <span><i class="fas fa-map-marker-alt"></i> {{ selectedWorkshop().type }}</span>
                </div>
            </div>

            <form [formGroup]="enrollWorkshopForm" (ngSubmit)="onSubmitWorkshopEnrollment()">
                <div class="form-section">
                    <h3>Enrollment Information</h3>
                    <div class="form-group">
                        <label class="form-label">Full Name *</label>
                        <input type="text" class="form-control" formControlName="name">
                    </div>
                    <div class="form-row">
                        <div class="form-group flex-1">
                            <label class="form-label">Email Address *</label>
                            <input type="email" class="form-control" formControlName="email">
                        </div>
                        <div class="form-group flex-1">
                            <label class="form-label">Phone Number *</label>
                            <input type="tel" class="form-control" formControlName="phone">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Organization/School (Optional)</label>
                        <input type="text" class="form-control" formControlName="organization">
                    </div>
                </div>

                <div class="form-section">
                    <h3>Enrollment Type</h3>
                    <div class="radio-group">
                        @if (currentUser().role === 'Instructor' || currentUser().role === 'Teacher' ||
                        currentUser().role === 'Researcher' || currentUser().role === 'Admin') {
                        <label class="radio-option">
                            <input type="radio" formControlName="enrollmentType" value="support">
                            <span>Practical Hands-on Support (Instructor)</span>
                        </label>
                        }
                        <label class="radio-option">
                            <input type="radio" formControlName="enrollmentType" value="learning">
                            <span>Learn (Student)</span>
                        </label>
                    </div>
                </div>

                <div class="form-group" style="margin-top: 2rem;">
                    <label class="checkbox-option">
                        <input type="checkbox" formControlName="acceptTerms">
                        <span>I agree to the workshop terms and conditions.</span>
                    </label>
                </div>

                <button type="submit" class="btn-submit" [disabled]="enrollWorkshopForm.invalid">
                    Confirm Enrollment
                </button>
            </form>
        </div>
        } @else {
        <div class="view-header centered">
            <h1 class="page-title">Workshops</h1>
            <p class="section-subtitle">Explore and enroll in upcoming practical learning sessions.</p>
        </div>

        <!-- Filter Panel -->
        <div class="filter-panel">
            <!-- Search Row -->
            <div class="search-row">
                <div class="search-input-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="search-input" [ngModel]="searchQuery()" (ngModelChange)="searchQuery.set($event)" placeholder="Search workshops, instructors, types...">
                    @if (searchQuery()) {
                    <button class="clear-btn" (click)="searchQuery.set('')" title="Clear search">
                        <i class="fas fa-times"></i>
                    </button>
                    }
                </div>
                @if (activeFilterCount() > 0) {
                <button class="clear-all-btn" (click)="clearFilters()">
                    <span><i class="fas fa-filter-circle-xmark"></i> Clear Filters</span>
                    <span class="badge">{{ activeFilterCount() }}</span>
                </button>
                }
            </div>

            <!-- Filters Row -->
            <div class="filters-row">
                <!-- Mode Filter -->
                <div class="filter-group">
                    <div class="filter-label"><i class="fas fa-wifi"></i> Mode</div>
                    <div class="toggle-group">
                        @for (mode of ['All', 'Online', 'Offline']; track mode) {
                        <button class="toggle-btn" [class.active]="modeFilter() === mode" (click)="modeFilter.set(mode)">
                            {{ mode }}
                        </button>
                        }
                    </div>
                </div>

                <!-- Date Filter -->
                <div class="filter-group">
                    <div class="filter-label"><i class="fas fa-calendar"></i> Date</div>
                    <div class="toggle-group">
                        @for (date of ['Any', 'Today', 'This Week', 'This Month']; track date) {
                        <button class="toggle-btn" [class.active]="dateFilter() === date" (click)="dateFilter.set(date)">
                            {{ date }}
                        </button>
                        }
                    </div>
                </div>

                <!-- Location Filter -->
                <div class="filter-group location-group">
                    <div class="filter-label"><i class="fas fa-map-marker-alt"></i> Location</div>
                    <div class="location-row">
                        <div class="location-input-wrap">
                            <i class="fas fa-city"></i>
                            <input type="text" class="location-input" [ngModel]="locationQuery()" (ngModelChange)="locationQuery.set($event)" placeholder="City or location">
                        </div>
                        <select class="dist-select" [ngModel]="maxDistance()" (ngModelChange)="maxDistance.set($event)">
                            <option value="0">All Distances</option>
                            <option value="10">Within 10km</option>
                            <option value="20">Within 20km</option>
                            <option value="50">Within 50km</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Workshop Grid -->
        @if (filteredWorkshops().length > 0) {
        <div class="course-grid">
            @for (workshop of filteredWorkshops(); track workshop.id) {
            <div class="course-card" (click)="selectWorkshop(workshop)">
                <div class="card-top">
                    <div class="course-icon">
                        <i class="fas fa-tools"></i>
                    </div>
                    <div class="mode-tag" [class.online]="workshop.type === 'Online'" [class.offline]="workshop.type === 'Offline'">
                        <i class="fas" [class.fa-globe]="workshop.type === 'Online'" [class.fa-map-pin]="workshop.type === 'Offline'"></i>
                        {{ workshop.type }}
                    </div>
                </div>
                <h3 class="course-title">{{ workshop.title }}</h3>
                <p class="course-desc">{{ workshop.description }}</p>
                <div class="course-meta">
                    <span><i class="fas fa-calendar-alt"></i> {{ workshop.date }}</span>
                    <span><i class="fas fa-hourglass-half"></i> {{ workshop.duration }}</span>
                    <span><i class="fas fa-map-marker-alt"></i> {{ workshop.city }}</span>
                    @if (workshop.type === 'Offline' && workshop.distance > 0) {
                    <span><i class="fas fa-ruler-horizontal"></i> {{ workshop.distance }}km away</span>
                    }
                </div>
                <div class="course-action">
                    <span>Enroll Now <i class="fas fa-chevron-right"></i></span>
                </div>
            </div>
            }
        </div>
        } @else {
        <div class="empty-search">
            <i class="fas fa-search"></i>
            <p><strong>No workshops found</strong> matching your filters.</p>
            <p style="font-size: 0.85rem; margin-top: 0.5rem;">Try adjusting your search criteria.</p>
        </div>
        }
    </div>
</app-layout>